<!DOCTYPE html>
<html>
  <head>
    <title>Smart Fridge Scanner</title>
    <script src="https://unpkg.com/html5-qrcode"></script>
    <style>
      body {
        font-family: Arial;
        text-align: center;
        background: #f5f5f5;
      }
      #reader {
        width: 300px;
        margin: auto;
      }
      button {
        padding: 10px 20px;
        margin-top: 10px;
        font-size: 16px;
      }
    </style>
  </head>

  <body>
    <h2>📦 Scan Product</h2>

    <div id="reader"></div>

    <p id="result">Scanned Code:</p>

    <button onclick="sendData()">Send to ESP32</button>

    <script>
      let scannedCode = "";

      function onScanSuccess(decodedText) {
        scannedCode = decodedText;
        document.getElementById("result").innerHTML =
          "Scanned Code: " + scannedCode;
      }

      let html5QrCode = new Html5Qrcode("reader");
      html5QrCode.start(
        { facingMode: "environment" },
        {
          fps: 10,
          qrbox: 250,
        },
        onScanSuccess,
      );

      function sendData() {
        if (scannedCode === "") {
          alert("Scan something first!");
          return;
        }

        let espIP = "http://192.168.x.x/scan?code=" + scannedCode;

        fetch(espIP)
          .then((res) => alert("Sent to ESP32!"))
          .catch((err) => alert("Error sending data"));
      }
    </script>
  </body>
</html>
